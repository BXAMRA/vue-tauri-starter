{
  "name": "vue-tauri-starter",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "vue-tsc -b && tauri build",
    "vite:dev": "vite",
    "vite:build": "vue-tsc -b && vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json",
    "cargo:clean": "cargo clean --manifest-path src-tauri/Cargo.toml",
    "cargo:update": "cargo update --manifest-path src-tauri/Cargo.toml",
    "remove-mobile-assets": "rm -rf src-tauri/icons/android src-tauri/icons/ios",
    "vite:clean": "rm -rf node_modules/.vite app"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-store": "~2.4.2",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.574.0",
    "reka-ui": "^2.8.0",
    "tailwind-merge": "^3.4.1",
    "tailwindcss": "^4.1.18",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.0",
    "@types/node": "^25.2.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.8.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.4"
  }
}
