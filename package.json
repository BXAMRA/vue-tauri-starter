{
  "name": "vue-tauri-starter",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "vue-tsc -b && tauri build",
    "vite:dev": "vite",
    "vite:build": "vue-tsc -b && vite build && vitepress build docs",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json",
    "cargo:clean": "cargo clean --manifest-path src-tauri/Cargo.toml",
    "cargo:update": "cargo update --manifest-path src-tauri/Cargo.toml",
    "create-desktop-icons": "tauri icon app-icon.png && rm -rf src-tauri/icons/android src-tauri/icons/ios",
    "vite:clean": "rm -rf node_modules/.vite app",
    "clean:all": "pnpm run cargo:clean && pnpm run vite:clean",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@internationalized/date": "^3.11.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/vue-table": "^8.21.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-store": "~2.4.2",
    "@unovis/vue": "^1.6.4",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-vue": "^8.6.0",
    "lucide-vue-next": "^0.574.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.8.0",
    "tailwind-merge": "^3.4.1",
    "tailwindcss": "^4.1.18",
    "vaul-vue": "^0.4.1",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.28",
    "vue-input-otp": "^0.3.2",
    "vue-router": "^4.6.4",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.0",
    "@types/node": "^25.2.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.8.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitepress": "2.0.0-alpha.16",
    "vue-tsc": "^3.2.4"
  }
}
